#include <iostream>
using namespace std;

int g_num1 = 10;

int adder(int n1, int n2) {
    int tmp = n1 + n2;
    return tmp;
}

int main() {
    int *ptr1 = new int;
    *ptr1 = 5;

    int a = 3, b = 5, c = 100;

    int *ptr2 = new int;
    *ptr2 = 10;

    c = adder(a, b);

    // OUTPUT
    cout << "a = " << a << endl;
    cout << "b = " << b << endl;
    cout << "c (a+b) = " << c << endl;
    cout << "ptr1 value = " << *ptr1 << endl;
    cout << "ptr2 value = " << *ptr2 << endl;
    cout << "Global g_num1 = " << g_num1 << endl;

    // free memory properly
    delete ptr1;
    delete ptr2;

    // keeps console open (works everywhere)
    cin.get();

    return 0;
}
